.combat-card {
    position: relative;
    width: 100%;
    height: 100%;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    overflow: visible;
}

.combat-card__card {
    width: 100%;
    height: 100%;
    flex-shrink: 0;
}

.combat-card__health-widget {
    position: relative;
    left: auto;
    top: auto;
    translate: 0 0;
    flex-shrink: 0;
    margin-bottom: 8px;
}
