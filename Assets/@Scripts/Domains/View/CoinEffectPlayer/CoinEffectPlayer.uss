.coin-effect {
    position: absolute;
    width: 28px;
    height: 28px;
}

.coin-effect__visual {
    width: 28px;
    height: 28px;
    border-width: 2px;
    border-radius: 14px;
}

.coin-effect__visual--heads {
    background-color: rgb(224, 183, 86);
    border-color: rgb(255, 233, 166);
}

.coin-effect__visual--tails {
    background-color: rgb(118, 105, 147);
    border-color: rgb(185, 171, 224);
}
