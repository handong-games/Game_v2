.skill-slot-widget {
    --ui-transition-offset-y: var(--ui-transition-offset-y-small-18px);
    width: 100%;
    height: 128px;
    flex-direction: row;
    justify-content: center;
    align-items: center;
}

.skill-slot-widget__slot {
    width: 128px;
    height: 128px;
    margin-left: 6px;
    margin-right: 6px;
    flex-shrink: 0;
    overflow: visible;
}
