    <Style src="project://database/Assets/@Scripts/Domains/View/EndTurnWidget/EndTurnWidget.uss?fileID=7433441132597879392&amp;guid=d07c021ad761488abf739058074c5687&amp;type=3#EndTurnWidget"/>
    <Style src="project://database/Assets/@Scripts/Domains/View/Adventure/AdventureView.uss?fileID=7433441132597879392&amp;guid=45a72d6395514e4986d12dec76e1ec7f&amp;type=3#AdventureView"/>
    <ui:VisualElement class="screen">
            <ui:VisualElement name="adventure-root" class="adventure-view">
                <ui:VisualElement name="adventure-background" class="adventure-view__background" picking-mode="Ignore"/>
                <ui:Instance template="CardBoardTemplate" name="adventure-card-board-template" class="adventure-view__card-board"/>
                <ui:VisualElement name="adventure-banner-area" class="adventure-view__banner-area" picking-mode="Ignore">
                    <ui:Instance template="BannerTemplate" name="adventure-banner-template" class="adventure-view__banner" picking-mode="Ignore"/>
                </ui:VisualElement>
            <ui:VisualElement name="adventure-bottom-hud-area" class="adventure-view__bottom-hud-area" picking-mode="Ignore">
                <ui:VisualElement name="adventure-coin-status-area" class="adventure-view__coin-status-area" picking-mode="Ignore">
                    <ui:Instance template="CoinStatusWidgetTemplate" name="adventure-coin-status-widget-template" class="adventure-view__coin-status-widget" picking-mode="Ignore"/>
                </ui:VisualElement>
                <ui:Instance template="SkillSlotWidgetTemplate" name="adventure-skill-slot-widget-template" class="adventure-view__skill-slot-widget" picking-mode="Ignore"/>
            </ui:VisualElement>
            <ui:Instance template="EndTurnWidgetTemplate" name="adventure-end-turn-widget-template" class="adventure-view__end-turn-widget"/>
            <ui:VisualElement name="adventure-hud-top-layer" class="adventure-view__hud-top-layer">
                <ui:Instance template="ResourceStatusBarTemplate" name="adventure-resource-status-bar-template" class="adventure-view__resource-status-bar" style="top: auto; left: auto;"/>
                <ui:VisualElement name="adventure-top-center-group" class="adventure-view__top-center-group">
                    <ui:Instance template="ProgressBarTemplate" name="adventure-progress-bar-template" class="adventure-view__progress-bar"/>
                    <ui:Instance template="CardDeckTemplate" name="adventure-card-deck-template" class="adventure-view__card-deck"/>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="adventure-effect-layer" class="adventure-view__effect-layer" picking-mode="Ignore">
                <widgets:ArrowWidget name="arrow-widget" class="arrow-widget" picking-mode="Ignore"/>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
