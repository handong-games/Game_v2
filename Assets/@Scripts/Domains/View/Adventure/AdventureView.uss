.adventure-view {
    width: 100%;
    height: 100%;
    flex-grow: 1;
    position: relative;
    overflow: hidden;
    background-color: rgb(0, 0, 0);
}

.adventure-view__card-board {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
}

.adventure-view__banner-area {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    justify-content: center;
    align-items: stretch;
}

.adventure-view__hud-top-layer {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    height: 104px;
}

.adventure-view__resource-status-bar {
    position: absolute;
    left: 24px;
    top: 18px;
}

.adventure-view__top-center-group {
    position: absolute;
    left: 0;
    top: 8px;
    right: 0;
    flex-direction: row;
    justify-content: center;
    align-items: flex-start;
}

.adventure-view__progress-bar {
    position: relative;
}

.adventure-view__card-deck {
    position: relative;
    margin-left: 32px;
}
